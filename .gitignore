# ════════════════════════════════════════════
#   EstateIQ — .gitignore
# ════════════════════════════════════════════

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────
.venv/
venv/
env/
ENV/
.virtualenv/

# ── Flask / SQLite ────────────────────────
instance/
*.db
*.sqlite
*.sqlite3

# ── ML Model Artefacts ────────────────────
# Comment these out if you want to commit a
# pre-trained model for deployment.
model/

# ── Dataset files ─────────────────────────
# Never commit raw data to git
*.csv
*.xlsx
*.xls
*.json.gz
data/
datasets/

# ── Environment Variables ─────────────────
.env
.env.*
!.env.example

# ── IDE / Editor ──────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────
*.log
logs/
log/

# ── Testing / Coverage ────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
nosetests.xml

# ── Jupyter ───────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker (keep compose, ignore generated)
.docker/

# ── Misc ──────────────────────────────────
*.bak
*.tmp
.cache/